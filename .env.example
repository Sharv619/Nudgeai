# NudgeAI environment template
# The core manual nudge MVP does not require external API keys.
# Keep real secrets in a local .env file only. Do not commit .env, token files,
# OAuth credentials, or generated Google sync outputs.

# Core local MVP stores used by simple_api_server.py
NUDGE_STORE_PATH=data/nudges.json
PLACES_STORE_PATH=data/places.json
CONTEXT_RULES_STORE_PATH=data/context_rules.json
RULE_STATE_STORE_PATH=data/rule_state.json
CURRENT_LOCATION_STORE_PATH=data/current_location.json
CALENDAR_AVAILABILITY_STORE_PATH=data/calendar_availability.json

# Frontend flags
# Vite reads VITE_* variables at build/dev-server startup.
VITE_USE_MOCK_DATA=false
# Legacy React flag still referenced by older frontend helper code.
REACT_APP_USE_MOCK_DATA=false

# AI extraction provider for POST /api/extract
# Default behavior is local-first: use rules unless a local endpoint is configured.
# Set EXTRACT_LLM_PROVIDER=local for Ollama/LlamaEdge, openai or mistral for external providers, or rules to force deterministic parsing.
EXTRACT_LLM_PROVIDER=rules
EXTRACT_LOCAL_LLM_URL=http://localhost:11434/api/generate
EXTRACT_LLM_MODEL=llama3.1
EXTRACT_LLM_TIMEOUT_SECONDS=8
# External providers are never used unless this is true and a provider/key is configured.
EXTRACT_ALLOW_EXTERNAL_LLM=false
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions

# Experimental MCP/RAG/Hugging Face paths only
HF_token=your_huggingface_token_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.1
WHITECIRCLE_API_KEY=your_whitecircle_api_key_here

# Experimental local Google sync/OAuth helpers only
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/
GOOGLE_TOKEN=your_google_access_token_here
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Experimental MCP HTTP bridge / Docker compose variables
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Optional demo asset generation scripts only
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here
